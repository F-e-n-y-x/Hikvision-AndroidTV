<?xml version="1.0" encoding="utf-8"?>
<!--
  This is a LAN app that talks to an NVR over plain HTTP (ISAPI on port 80) and RTSP.
  Android 9+ blocks cleartext by default, so we explicitly allow it (the NVR IP is user-entered
  at runtime, so it can't be a static domain allow-list).

  We do NOT globally trust user-installed CAs: that would let a rogue user CA MITM the app's real
  HTTPS traffic (e.g. EZVIZ cloud login). The NVR's own self-signed cert is trusted in code, scoped
  to the single configured host (see IsapiClient.trustSelfSigned), so HTTPS to the NVR still works.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
